package templates

import (
	"github.com/luminor-project/luminor-core-go-playground/internal/common/web/templates/layouts"
	"github.com/luminor-project/luminor-core-go-playground/internal/platform/i18n"
)

templ ForgotPasswordSent() {
	@layouts.AppShell(i18n.T(ctx, "auth.forgotPasswordSent.pageTitle")) {
		<div data-test-id="forgot-password-sent-page">
			@layouts.CenteredPanel() {
				<div class="text-center space-y-4">
					<h1 class="lmn-h1" data-test-id="forgot-password-sent-heading">{ i18n.T(ctx, "auth.forgotPasswordSent.heading") }</h1>
					<p class="lmn-text">{ i18n.T(ctx, "auth.forgotPasswordSent.message") }</p>
					<a href={ i18n.LocalizedPath(ctx, "/sign-in") } class="lmn-button-default inline-block" data-test-id="forgot-password-sent-back">{ i18n.T(ctx, "auth.forgotPasswordSent.backToSignIn") }</a>
				</div>
			}
		</div>
	}
}
